Dashboard

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AssetFlow - Dashboard</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <div class="logo-container">
                <div class="logo-box">A</div>
                <div class="app-title">AssetFlow</div>
            </div>
            <div style="color: #6b7280; font-size: 14px; font-weight: 600;">Admin Console</div>
        </header>
        <div class="app-body">
            <nav class="sidebar">
                <a href="dashboard.html" class="sidebar-link active">Dashboard</a>
                <a href="orgsetup.html" class="sidebar-link">Organization setup</a>
                <a href="assets.html" class="sidebar-link">Assets</a>
                <a href="allocation.html" class="sidebar-link">Allocation & Transfer</a>
                <a href="booking.html" class="sidebar-link">Resource Booking</a>
                <a href="maintenance.html" class="sidebar-link">Maintenance</a>
                <a href="audit.html" class="sidebar-link">Audit</a>
                <a href="reports.html" class="sidebar-link">Reports</a>
                <a href="notifications.html" class="sidebar-link">Notifications</a>
            </nav>
            <main class="main-content">
                <div>
                    <h2 class="page-title">Operational Dashboard</h2>
                    <div class="subtitle">Real-time status overview of organizational assets</div>
                </div>

                <div class="kpi-grid">
                    <div class="kpi-card">
                        <div class="kpi-value" id="kpiAvailable">1</div>
                        <div class="kpi-label">Assets Available</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-value" id="kpiAllocated">1</div>
                        <div class="kpi-label">Assets Allocated</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-value" id="kpiMaintenance">1</div>
                        <div class="kpi-label">Under Maintenance</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-value" id="kpiBookings">2</div>
                        <div class="kpi-label">Active Bookings</div>
                    </div>
                </div>

                <div class="content-card">
                    <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 15px;">Quick Operations</h3>
                    <div style="display: flex; gap: 12px; flex-wrap: wrap;">
                        <a href="assets.html" class="btn-brand" style="text-decoration: none;">+ Register Asset</a>
                        <a href="booking.html" class="btn-brand" style="text-decoration: none;">Book Resource</a>
                        <a href="maintenance.html" class="btn-brand" style="text-decoration: none;">Raise Maintenance</a>
                    </div>
                </div>

                <div class="info-box" style="text-align: left;">
                    ℹ️ AssetFlow tracks dynamic allocations, resource double-booking, and audit cycles. Click the sidebar links to navigate.
                </div>
            </main>
        </div>
    </div>

    <script>
        // Simply pull some metrics from localStorage or defaults
        function updateKPIs() {
            // Available is 1 (AF-0201), Allocated is 1 (AF-0012), Maintenance is 1 (AF-0062)
            // Just displaying static counts or loading from directories if present
            document.getElementById('kpiAvailable').innerText = '1';
            document.getElementById('kpiAllocated').innerText = '1';
            document.getElementById('kpiMaintenance').innerText = '1';
            document.getElementById('kpiBookings').innerText = '2';
        }
        updateKPIs();
    </script>
</body>
</html>
