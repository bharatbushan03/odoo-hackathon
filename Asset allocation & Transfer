<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AssetFlow - Screen 5 Asset allocation & Transfer</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <div class="logo-container">
                <div class="logo-box">A</div>
                <div class="app-title">AssetFlow</div>
            </div>
            <div style="color: #6b7280; font-size: 14px; font-weight: 600;">Admin Console</div>
        </header>
        <div class="app-body">
            <nav class="sidebar">
                <a href="Screen 2 Dashboard.html" class="sidebar-link">Dashboard</a>
                <a href="Screen 3 Organization setup.html" class="sidebar-link">Organization setup</a>
                <a href="Screen 4 Asset registrations and directory.html" class="sidebar-link">Assets</a>
                <a href="Screen 5 Asset allocation & Transfer.html" class="sidebar-link active">Allocation & Transfer</a>
                <a href="Screen 6 Resource booking.html" class="sidebar-link">Resource Booking</a>
                <a href="Screen 7 Maintenance Management.html" class="sidebar-link">Maintenance</a>
                <a href="Screen 8 Asset Audit.html" class="sidebar-link">Audit</a>
                <a href="Screen 9 Reports & Analytics.html" class="sidebar-link">Reports</a>
                <a href="Screen 10 Activity logs & Notifications.html" class="sidebar-link">Notifications</a>
            </nav>
            <main class="main-content">
                <div class="content-card" style="max-width: 700px;">
                    <h2 class="page-title">Screen 5 Asset allocation & Transfer</h2>
                    <div class="subtitle">Assign ownership or request transfers for already allocated assets</div>

                    <!-- Asset Selector -->
                    <div>
                        <span class="label">Asset</span>
                        <select id="assetSelect" onchange="handleAssetChange()" style="margin-bottom: 20px;">
                            <option value="AF-0114 - Dell laptop">AF-0114 - Dell laptop (Allocated)</option>
                            <option value="AF-0201 - Office chair">AF-0201 - Office chair (Available)</option>
                            <option value="AF-0062 - Projector">AF-0062 - Projector (Maintenance)</option>
                        </select>
                    </div>

                    <!-- Warning double allocation block -->
                    <div class="warning-box" id="allocationWarning" style="margin-bottom: 20px;">
                        ⚠️ Already Allocated to Priya shah (Engineering) <br>
                        Direct re-allocation is blocked - submit a transfer request below
                    </div>

                    <!-- Transfer Form -->
                    <div id="transferFormSection">
                        <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 12px; border-bottom: 1px solid #e5e7eb; padding-bottom: 6px;">Transfer Request</h3>
                        <form onsubmit="handleTransferSubmit(event)">
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                                <div>
                                    <span class="label" style="margin-top: 5px;">From</span>
                                    <input type="text" id="transferFrom" value="Priya Shah" readonly style="background: #f3f4f6; color: #4b5563;">
                                </div>
                                <div>
                                    <span class="label" style="margin-top: 5px;">To</span>
                                    <select id="transferTo" required>
                                        <option value="">Select Employee...</option>
                                        <option value="Raj Nair">Raj Nair (Engineering)</option>
                                        <option value="Sana Iqbal">Sana Iqbal (Field ops)</option>
                                        <option value="Arjun Nair">Arjun Nair (Logistics)</option>
                                    </select>
                                </div>
                            </div>
                            <div>
                                <span class="label">Reason</span>
                                <textarea id="transferReason" style="height: 100px; resize: none;" placeholder="Explain why this transfer is required..." required></textarea>
                            </div>
                            <div style="margin-top: 15px;">
                                <button type="submit" class="btn-brand">Submit Request</button>
                            </div>
                        </form>
                    </div>

                    <!-- Direct Allocation Form (Initially Hidden) -->
                    <div id="directFormSection" style="display: none;">
                        <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 12px; border-bottom: 1px solid #e5e7eb; padding-bottom: 6px;">Direct Allocation</h3>
                        <form onsubmit="handleDirectSubmit(event)">
                            <div>
                                <span class="label" style="margin-top: 5px;">Assign To Employee</span>
                                <select id="directTo" required>
                                    <option value="">Select Employee...</option>
                                    <option value="Priya Shah">Priya Shah (Engineering)</option>
                                    <option value="Raj Nair">Raj Nair (Engineering)</option>
                                    <option value="Sana Iqbal">Sana Iqbal (Field ops)</option>
                                    <option value="Arjun Nair">Arjun Nair (Logistics)</option>
                                </select>
                            </div>
                            <div>
                                <span class="label">Expected Return Date (Optional)</span>
                                <input type="date" id="directReturnDate">
                            </div>
                            <div style="margin-top: 15px;">
                                <button type="submit" class="btn-primary">Allocate Asset</button>
                            </div>
                        </form>
                    </div>

                    <!-- Allocation History List -->
                    <div style="margin-top: 30px;">
                        <h3 style="font-size: 16px; font-weight: 700; border-bottom: 1px solid #e5e7eb; padding-bottom: 8px; margin-bottom: 12px;">Allocation history</h3>
                        <div id="historyList" style="font-size: 14px; color: #4b5563; line-height: 1.8;">
                            <!-- Injected dynamically -->
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script>
        let historyLogs = [
            { date: "Mar 12", text: "Allocated to Priya shah - Engineering" },
            { date: "Jan 04", text: "Returned by Arjun Nair - condition: good" }
        ];

        function renderHistory() {
            const container = document.getElementById('historyList');
            container.innerHTML = '';
            historyLogs.forEach(log => {
                const item = document.createElement('div');
                item.innerHTML = `<strong>${log.date}</strong> - ${log.text}`;
                container.appendChild(item);
            });
        }

        function handleAssetChange() {
            const assetVal = document.getElementById('assetSelect').value;
            const warning = document.getElementById('allocationWarning');
            const transferForm = document.getElementById('transferFormSection');
            const directForm = document.getElementById('directFormSection');

            if (assetVal === 'AF-0114 - Dell laptop') {
                warning.style.display = 'block';
                transferForm.style.display = 'block';
                directForm.style.display = 'none';
            } else if (assetVal === 'AF-0201 - Office chair') {
                warning.style.display = 'none';
                transferForm.style.display = 'none';
                directForm.style.display = 'block';
            } else {
                warning.className = 'warning-box';
                warning.style.display = 'block';
                warning.innerHTML = '⚠️ This asset is currently under Maintenance. Direct allocation and transfer are disabled.';
                transferForm.style.display = 'none';
                directForm.style.display = 'none';
            }
        }

        function handleTransferSubmit(e) {
            e.preventDefault();
            const from = document.getElementById('transferFrom').value;
            const to = document.getElementById('transferTo').value;
            const reason = document.getElementById('transferReason').value;

            const today = new Date();
            const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
            const dateStr = `${months[today.getMonth()]} ${String(today.getDate()).padStart(2, '0')}`;

            historyLogs.unshift({
                date: dateStr,
                text: `Transfer requested from ${from} to ${to} (Reason: ${reason})`
            });

            addNotificationLog(`Transfer request submitted for AF-0114 to ${to}`, 'approvals', 'red');

            alert(`Transfer request submitted successfully. It will route to approval!`);
            document.getElementById('transferReason').value = '';
            document.getElementById('transferTo').value = '';
            renderHistory();
        }

        function handleDirectSubmit(e) {
            e.preventDefault();
            const to = document.getElementById('directTo').value;
            
            const today = new Date();
            const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
            const dateStr = `${months[today.getMonth()]} ${String(today.getDate()).padStart(2, '0')}`;

            historyLogs.unshift({
                date: dateStr,
                text: `Allocated directly to ${to}`
            });

            addNotificationLog(`Asset AF-0201 allocated to ${to}`, 'bookings', 'blue');

            alert(`Asset allocated directly to ${to}!`);
            document.getElementById('directTo').value = '';
            renderHistory();
        }

        function addNotificationLog(text, type, indicator) {
            let notifs = JSON.parse(localStorage.getItem('assetflow_local_notifs')) || [];
            notifs.unshift({
                id: Date.now(),
                text,
                time: 'Just now',
                type,
                indicator
            });
            localStorage.setItem('assetflow_local_notifs', JSON.stringify(notifs));
        }

        renderHistory();
        handleAssetChange();
    </script>
</body>
</html>
