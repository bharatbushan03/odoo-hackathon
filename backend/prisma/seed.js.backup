const { PrismaClient } = require('@prisma/client');
const { hashPassword } = require('../src/utils/password');

const prisma = new PrismaClient();

async function main() {
  console.log('Starting database seeding...');

  // Create default organization
  const org = await prisma.organization.upsert({
    where: { id: 'seed-org-main' },
    update: {},
    create: {
      id: 'seed-org-main',
      name: 'Main Organization',
      code: 'MAIN',
      email: 'admin@mainorg.com',
      isActive: true,
    },
  });

  // Create default roles
  const rolesData = [
    {
      name: 'SUPER_ADMIN',
      description: 'Super Administrator with full system access',
      isSystem: true,
      organizationId: org.id,
    },
    {
      name: 'ORG_ADMIN',
      description: 'Organization Administrator with access to organization-wide features',
      isSystem: true,
      organizationId: org.id,
    },
    {
      name: 'ASSET_MANAGER',
      description: 'Asset Manager responsible for managing assets',
      isSystem: true,
      organizationId: org.id,
    },
    {
      name: 'DEPT_HEAD',
      description: 'Department Head responsible for managing a department',
      isSystem: true,
      organizationId: org.id,
    },
    {
      name: 'EMPLOYEE',
      description: 'Regular employee with basic access',
      isSystem: true,
      organizationId: org.id,
    },
    {
      name: 'AUDITOR',
      description: 'Auditor with read-only access to system data',
      isSystem: true,
      organizationId: org.id,
    },
  ];

  const createdRoles = {};
  for (const roleData of rolesData) {
    const role = await prisma.role.upsert({
      where: {
        name_organizationId: {
          name: roleData.name,
          organizationId: org.id,
        },
      },
      update: {},
      create: roleData,
    });
    createdRoles[roleData.name] = role;
    console.log(`Created role: ${role.name}`);
  }

  // Create department
  const dept = await prisma.department.upsert({
    where: { id: 'seed-dept-engineering' },
    update: {},
    create: {
      id: 'seed-dept-engineering',
      name: 'Engineering',
      organizationId: org.id,
      status: 'ACTIVE',
    },
  });

  // Create admin user with SUPER_ADMIN role
  const adminUser = await prisma.employee.upsert({
    where: { email: 'admin@company.com' },
    update: {},
    create: {
      name: 'System Administrator',
      email: 'admin@company.com',
      password: hashPassword('Admin@12345'),
      roleId: createdRoles.SUPER_ADMIN.id,
      organizationId: org.id,
      departmentId: dept.id,
      emailVerified: true,
    },
  });

  // Create regular employee with EMPLOYEE role
  const regularUser = await prisma.employee.upsert({
    where: { email: 'employee@company.com' },
    update: {},
    create: {
      name: 'Demo Employee',
      email: 'employee@company.com',
      password: hashPassword('Employee@123'),
      roleId: createdRoles.EMPLOYEE.id,
      organizationId: org.id,
      departmentId: dept.id,
      emailVerified: true,
    },
  });

  console.log('Seeding complete.');
  console.log('  Super Admin: admin@company.com / Admin@12345');
  console.log('  Employee:    employee@company.com / Employee@123');
}

main()
  .catch((err) => {
    console.error('Seeding failed:', err);
    process.exit(1);
  })
  .finally(() => prisma.$disconnect());
