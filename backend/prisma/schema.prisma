generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPT_HEAD
  EMPLOYEE
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  Available
  Allocated
  Reserved
  UnderMaintenance
  Lost
  Retired
  Disposed
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum Condition {
  NEW
  GOOD
  FAIR
  POOR
}

model Department {
  id          String           @id @default(uuid())
  name        String
  parentId    String?
  parent      Department?      @relation("DeptHierarchy", fields: [parentId], references: [id])
  children    Department[]     @relation("DeptHierarchy")
  status      DepartmentStatus @default(ACTIVE)
  employees   Employee[]
  assets      Asset[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("departments")
}

model Employee {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  password     String
  role         Role        @default(EMPLOYEE)
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?
  raisedMaintenanceRequests MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  technicianMaintenanceRequests MaintenanceRequest[] @relation("MaintenanceTechnician")
  bookings Booking[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("employees")
}

model AssetCategory {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  customFields Json?
  assets       Asset[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("asset_categories")
}

model Asset {
  id                  String             @id @default(uuid())
  name                String
  assetTag            String             @unique
  serialNumber        String?            @unique
  acquisitionDate     DateTime
  cost                Float
  condition           Condition          @default(GOOD)
  location            String
  shared              Boolean            @default(false)
  bookable            Boolean            @default(false)
  status              AssetStatus        @default(Available)
  category            AssetCategory      @relation(fields: [categoryId], references: [id])
  categoryId          String
  department          Department?        @relation(fields: [departmentId], references: [id])
  departmentId        String?
  allocations         Allocation[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@map("assets")
}

model Allocation {
  id                String          @id @default(uuid())
  asset             Asset           @relation(fields: [assetId], references: [id])
  assetId           String
  holderType        String
  holderId          String
  holderName        String
  expectedReturnDate DateTime?
  actualReturnDate  DateTime?
  status            AllocationStatus @default(ACTIVE)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("allocations")
}

model Booking {
  id         String       @id @default(uuid())
  asset      Asset        @relation(fields: [assetId], references: [id])
  assetId    String
  user       Employee     @relation(fields: [userId], references: [id])
  userId     String
  startTime  DateTime
  endTime    DateTime
  status     BookingStatus @default(UPCOMING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@map("bookings")
}

model MaintenanceRequest {
  id           String            @id @default(uuid())
  asset        Asset             @relation(fields: [assetId], references: [id])
  assetId      String
  raisedBy     Employee          @relation("MaintenanceRaisedBy", fields: [raisedById], references: [id])
  raisedById   String
  issue        String
  priority     String
  photo        String?
  status       MaintenanceStatus @default(PENDING)
  technician   Employee?         @relation("MaintenanceTechnician", fields: [technicianId], references: [id])
  technicianId String?
  resolvedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@map("maintenance_requests")
}
