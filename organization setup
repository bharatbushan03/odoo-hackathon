<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AssetFlow - Screen 3 Organization setup</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <div class="logo-container">
                <div class="logo-box">A</div>
                <div class="app-title">AssetFlow</div>
            </div>
            <div style="color: #6b7280; font-size: 14px; font-weight: 600;">Admin Console</div>
        </header>
        <div class="app-body">
            <nav class="sidebar">
                <a href="Screen 2 Dashboard.html" class="sidebar-link">Dashboard</a>
                <a href="Screen 3 Organization setup.html" class="sidebar-link active">Organization setup</a>
                <a href="Screen 4 Asset registrations and directory.html" class="sidebar-link">Assets</a>
                <a href="Screen 5 Asset allocation & Transfer.html" class="sidebar-link">Allocation & Transfer</a>
                <a href="Screen 6 Resource booking.html" class="sidebar-link">Resource Booking</a>
                <a href="Screen 7 Maintenance Management.html" class="sidebar-link">Maintenance</a>
                <a href="Screen 8 Asset Audit.html" class="sidebar-link">Audit</a>
                <a href="Screen 9 Reports & Analytics.html" class="sidebar-link">Reports</a>
                <a href="Screen 10 Activity logs & Notifications.html" class="sidebar-link">Notifications</a>
            </nav>
            <main class="main-content">
                <div class="content-card">
                    <h2 class="page-title">Screen 3 Organization setup (Admin only)</h2>
                    <div class="subtitle">Maintain departments, asset categories, and company employees</div>

                    <div class="org-subtabs" style="display: flex; justify-content: space-between; align-items: center;">
                        <div style="display: flex; gap: 10px;">
                            <button id="tabDept" class="org-subtab active" onclick="switchSubTab('departments')">Departments</button>
                            <button id="tabCat" class="org-subtab" onclick="switchSubTab('categories')">Categories</button>
                            <button id="tabEmp" class="org-subtab" onclick="switchSubTab('employees')">Employee</button>
                        </div>
                        <button class="btn-brand" onclick="openAddModal()">+ Add</button>
                    </div>

                    <!-- Departments Tab Panel -->
                    <div id="panelDepartments" class="tab-panel">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Department</th>
                                    <th>Head</th>
                                    <th>Parent Dept</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody id="deptTableBody">
                                <!-- Dynamic rows -->
                            </tbody>
                        </table>
                    </div>

                    <!-- Categories Tab Panel -->
                    <div id="panelCategories" class="tab-panel" style="display: none;">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Category Name</th>
                                    <th>Required Fields</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody id="catTableBody">
                                <!-- Dynamic rows -->
                            </tbody>
                        </table>
                    </div>

                    <!-- Employees Tab Panel -->
                    <div id="panelEmployees" class="tab-panel" style="display: none;">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Department</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody id="empTableBody">
                                <!-- Dynamic rows -->
                            </tbody>
                        </table>
                    </div>

                    <div class="info-box" style="margin-top: 25px; text-align: left;">
                        Editing a department here also drives the picklist in Screen 4 & 5.
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Modal Form for + Add -->
    <div class="modal-overlay" id="addModal" style="display: none;">
        <form class="modal-content" onsubmit="handleAddSubmit(event)">
            <div class="modal-header" id="modalTitle">Add New Department</div>
            
            <div id="modalFormFields">
                <!-- Fields are injected dynamically depending on active sub-tab -->
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-secondary" onclick="closeAddModal()">Cancel</button>
                <button type="submit" class="btn-primary">Add Entry</button>
            </div>
        </form>
    </div>

    <script>
        let departments = [
            { name: "Engineering", head: "aditi rao", parent: "--", status: "Active" },
            { name: "Facilities", head: "rohan mehta", parent: "--", status: "Active" },
            { name: "Field ops (east)", head: "sana iqbal", parent: "Field Ops", status: "Inactive" }
        ];

        let categories = [
            { name: "Electronics", fields: "Warranty, Serial Number", status: "Active" },
            { name: "Furniture", fields: "Dimensions, Material", status: "Active" },
            { name: "Vehicles", fields: "License Plate, Mileage", status: "Active" }
        ];

        let employees = [
            { name: "Priya Shah", email: "priya@company.com", dept: "Engineering", role: "Employee", status: "Active" },
            { name: "Raj Nair", email: "raj@company.com", dept: "Engineering", role: "Department Head", status: "Active" },
            { name: "Sana Iqbal", email: "sana@company.com", dept: "Field ops (east)", role: "Asset Manager", status: "Active" }
        ];

        let activeTab = 'departments';

        function switchSubTab(tab) {
            activeTab = tab;
            document.getElementById('tabDept').classList.remove('active');
            document.getElementById('tabCat').classList.remove('active');
            document.getElementById('tabEmp').classList.remove('active');

            document.getElementById('panelDepartments').style.display = 'none';
            document.getElementById('panelCategories').style.display = 'none';
            document.getElementById('panelEmployees').style.display = 'none';

            if (tab === 'departments') {
                document.getElementById('tabDept').classList.add('active');
                document.getElementById('panelDepartments').style.display = 'block';
            } else if (tab === 'categories') {
                document.getElementById('tabCat').classList.add('active');
                document.getElementById('panelCategories').style.display = 'block';
            } else if (tab === 'employees') {
                document.getElementById('tabEmp').classList.add('active');
                document.getElementById('panelEmployees').style.display = 'block';
            }
            renderTables();
        }

        function renderTables() {
            const deptTbody = document.getElementById('deptTableBody');
            deptTbody.innerHTML = '';
            departments.forEach((d, i) => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><strong>${d.name}</strong></td>
                    <td>${d.head}</td>
                    <td>${d.parent}</td>
                    <td>
                        <span class="badge-pill ${d.status === 'Active' ? 'badge-pill-verified' : 'badge-pill-damaged'}" onclick="toggleDeptStatus(${i})" style="cursor:pointer;">
                            ${d.status}
                        </span>
                    </td>
                `;
                deptTbody.appendChild(tr);
            });

            const catTbody = document.getElementById('catTableBody');
            catTbody.innerHTML = '';
            categories.forEach((c, i) => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><strong>${c.name}</strong></td>
                    <td>${c.fields}</td>
                    <td>
                        <span class="badge-pill ${c.status === 'Active' ? 'badge-pill-verified' : 'badge-pill-damaged'}" onclick="toggleCatStatus(${i})" style="cursor:pointer;">
                            ${c.status}
                        </span>
                    </td>
                `;
                catTbody.appendChild(tr);
            });

            const empTbody = document.getElementById('empTableBody');
            empTbody.innerHTML = '';
            employees.forEach((e, i) => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><strong>${e.name}</strong></td>
                    <td>${e.email}</td>
                    <td>${e.dept}</td>
                    <td style="color:#2563eb; font-weight:bold;">${e.role}</td>
                    <td>
                        <span class="badge-pill ${e.status === 'Active' ? 'badge-pill-verified' : 'badge-pill-damaged'}" onclick="toggleEmpStatus(${i})" style="cursor:pointer;">
                            ${e.status}
                        </span>
                    </td>
                `;
                empTbody.appendChild(tr);
            });
        }

        function toggleDeptStatus(idx) {
            departments[idx].status = departments[idx].status === 'Active' ? 'Inactive' : 'Active';
            renderTables();
        }

        function toggleCatStatus(idx) {
            categories[idx].status = categories[idx].status === 'Active' ? 'Inactive' : 'Active';
            renderTables();
        }

        function toggleEmpStatus(idx) {
            employees[idx].status = employees[idx].status === 'Active' ? 'Inactive' : 'Active';
            renderTables();
        }

        function openAddModal() {
            const title = document.getElementById('modalTitle');
            const fieldsContainer = document.getElementById('modalFormFields');
            fieldsContainer.innerHTML = '';

            if (activeTab === 'departments') {
                title.innerText = 'Add New Department';
                fieldsContainer.innerHTML = `
                    <div>
                        <span class="label">Department Name</span>
                        <input type="text" id="addDeptName" required>
                    </div>
                    <div>
                        <span class="label">Department Head</span>
                        <input type="text" id="addDeptHead" required>
                    </div>
                    <div>
                        <span class="label">Parent Department (Optional)</span>
                        <input type="text" id="addDeptParent" placeholder="e.g. Field Ops">
                    </div>
                `;
            } else if (activeTab === 'categories') {
                title.innerText = 'Add New Category';
                fieldsContainer.innerHTML = `
                    <div>
                        <span class="label">Category Name</span>
                        <input type="text" id="addCatName" required>
                    </div>
                    <div>
                        <span class="label">Custom Fields (comma separated)</span>
                        <input type="text" id="addCatFields" placeholder="e.g. Warranty, Dimensions" required>
                    </div>
                `;
            } else if (activeTab === 'employees') {
                title.innerText = 'Add New Employee';
                let deptOptions = departments.map(d => `<option value="${d.name}">${d.name}</option>`).join('');
                fieldsContainer.innerHTML = `
                    <div>
                        <span class="label">Employee Name</span>
                        <input type="text" id="addEmpName" required>
                    </div>
                    <div>
                        <span class="label">Email Address</span>
                        <input type="email" id="addEmpEmail" required>
                    </div>
                    <div>
                        <span class="label">Department</span>
                        <select id="addEmpDept">
                            ${deptOptions}
                        </select>
                    </div>
                    <div>
                        <span class="label">Role</span>
                        <select id="addEmpRole">
                            <option value="Employee">Employee</option>
                            <option value="Department Head">Department Head</option>
                            <option value="Asset Manager">Asset Manager</option>
                        </select>
                    </div>
                `;
            }

            document.getElementById('addModal').style.display = 'flex';
        }

        function closeAddModal() {
            document.getElementById('addModal').style.display = 'none';
        }

        function handleAddSubmit(e) {
            e.preventDefault();
            if (activeTab === 'departments') {
                const name = document.getElementById('addDeptName').value;
                const head = document.getElementById('addDeptHead').value;
                const parent = document.getElementById('addDeptParent').value || '--';
                departments.push({ name, head, parent, status: 'Active' });
            } else if (activeTab === 'categories') {
                const name = document.getElementById('addCatName').value;
                const fields = document.getElementById('addCatFields').value;
                categories.push({ name, fields, status: 'Active' });
            } else if (activeTab === 'employees') {
                const name = document.getElementById('addEmpName').value;
                const email = document.getElementById('addEmpEmail').value;
                const dept = document.getElementById('addEmpDept').value;
                const role = document.getElementById('addEmpRole').value;
                employees.push({ name, email, dept, role, status: 'Active' });
            }
            renderTables();
            closeAddModal();
        }

        renderTables();
    </script>
</body>
</html>
