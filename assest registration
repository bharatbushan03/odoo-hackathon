

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AssetFlow - Screen 4 Assets Directory</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <div class="logo-container">
                <div class="logo-box">A</div>
                <div class="app-title">AssetFlow</div>
            </div>
            <div style="color: #6b7280; font-size: 14px; font-weight: 600;">Admin Console</div>
        </header>
        <div class="app-body">
            <nav class="sidebar">
                <a href="Screen 2 Dashboard.html" class="sidebar-link">Dashboard</a>
                <a href="Screen 3 Organization setup.html" class="sidebar-link">Organization setup</a>
                <a href="Screen 4 Asset registrations and directory.html" class="sidebar-link active">Assets</a>
                <a href="Screen 5 Asset allocation & Transfer.html" class="sidebar-link">Allocation & Transfer</a>
                <a href="Screen 6 Resource booking.html" class="sidebar-link">Resource Booking</a>
                <a href="Screen 7 Maintenance Management.html" class="sidebar-link">Maintenance</a>
                <a href="Screen 8 Asset Audit.html" class="sidebar-link">Audit</a>
                <a href="Screen 9 Reports & Analytics.html" class="sidebar-link">Reports</a>
                <a href="Screen 10 Activity logs & Notifications.html" class="sidebar-link">Notifications</a>
            </nav>
            <main class="main-content">
                <div class="content-card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <div>
                            <h2 class="page-title">Screen 4 Asset registrations and directory</h2>
                            <div class="subtitle" style="margin-bottom: 0;">Central directory to search, filter, and register organizational items</div>
                        </div>
                        <button class="btn-brand" onclick="openRegisterModal()">+ Register Asset</button>
                    </div>

                    <div style="display: flex; gap: 15px; margin-bottom: 20px; flex-wrap: wrap;">
                        <div style="flex: 2; min-width: 250px;">
                            <input type="text" id="searchInput" placeholder="Search by tag, serial, or QR code..." oninput="filterAssets()">
                        </div>
                        <div style="flex: 1; min-width: 150px;">
                            <select id="filterCategory" onchange="filterAssets()">
                                <option value="All">Category (All)</option>
                                <option value="Electronics">Electronics</option>
                                <option value="Furniture">Furniture</option>
                                <option value="Vehicles">Vehicles</option>
                            </select>
                        </div>
                        <div style="flex: 1; min-width: 150px;">
                            <select id="filterStatus" onchange="filterAssets()">
                                <option value="All">Status (All)</option>
                                <option value="Available">Available</option>
                                <option value="Allocated">Allocated</option>
                                <option value="Maintenance">Maintenance</option>
                            </select>
                        </div>
                        <div style="flex: 1; min-width: 150px;">
                            <select id="filterDepartment" onchange="filterAssets()">
                                <option value="All">Department (All)</option>
                                <option value="Engineering">Engineering</option>
                                <option value="Finance">Finance</option>
                                <option value="Marketing">Marketing</option>
                                <option value="Logistics">Logistics</option>
                                <option value="Facilities">Facilities</option>
                            </select>
                        </div>
                    </div>

                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Tag</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Status</th>
                                <th>Location</th>
                            </tr>
                        </thead>
                        <tbody id="assetsTableBody">
                            <!-- Injected dynamically -->
                        </tbody>
                    </table>
                </div>
            </main>
        </div>
    </div>

    <!-- Register Asset Modal -->
    <div class="modal-overlay" id="registerModal" style="display: none;">
        <form class="modal-content" onsubmit="handleRegisterSubmit(event)">
            <div class="modal-header">Register New Asset</div>
            
            <div>
                <span class="label">Asset Name</span>
                <input type="text" id="addAssetName" placeholder="e.g. HP LaserJet Printer" required>
            </div>
            <div>
                <span class="label">Category</span>
                <select id="addAssetCategory">
                    <option value="Electronics">Electronics</option>
                    <option value="Furniture">Furniture</option>
                    <option value="Vehicles">Vehicles</option>
                </select>
            </div>
            <div>
                <span class="label">Serial Number</span>
                <input type="text" id="addAssetSerial" placeholder="e.g. SN-89745" required>
            </div>
            <div>
                <span class="label">Location</span>
                <input type="text" id="addAssetLocation" placeholder="e.g. HQ Floor 2" required>
            </div>
            <div>
                <span class="label">Status</span>
                <select id="addAssetStatus">
                    <option value="Available">Available</option>
                    <option value="Allocated">Allocated</option>
                    <option value="Maintenance">Maintenance</option>
                </select>
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-secondary" onclick="closeRegisterModal()">Cancel</button>
                <button type="submit" class="btn-primary">Register</button>
            </div>
        </form>
    </div>

    <script>
        let assets = [
            { id: "AF-0012", name: "Dell Laptop", category: "Electronics", status: "Allocated", location: "bengaluru", dept: "Engineering" },
            { id: "AF-0062", name: "Projector", category: "Electronics", status: "Maintenance", location: "HQ Floor 2", dept: "Facilities" },
            { id: "AF-0201", name: "Office chair", category: "Furniture", status: "Available", location: "Warehouse", dept: "Logistics" }
        ];

        function renderAssets(filteredArr = assets) {
            const tbody = document.getElementById('assetsTableBody');
            tbody.innerHTML = '';

            if (filteredArr.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; color: #9ca3af; padding: 20px;">No matching assets found</td></tr>';
                return;
            }

            filteredArr.forEach(a => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td style="font-weight: bold; color: #111827;">${a.id}</td>
                    <td>${a.name}</td>
                    <td>${a.category}</td>
                    <td style="font-weight: bold; color: ${
                        a.status === 'Available' ? '#047857' : 
                        a.status === 'Allocated' ? '#2563eb' : '#d97706'
                    }">${a.status}</td>
                    <td>${a.location}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterAssets() {
            const query = document.getElementById('searchInput').value.toLowerCase();
            const cat = document.getElementById('filterCategory').value;
            const status = document.getElementById('filterStatus').value;
            const dept = document.getElementById('filterDepartment').value;

            const filtered = assets.filter(a => {
                const matchesQuery = a.id.toLowerCase().includes(query) || a.name.toLowerCase().includes(query) || a.location.toLowerCase().includes(query);
                const matchesCat = cat === 'All' || a.category === cat;
                const matchesStatus = status === 'All' || a.status === status;
                const matchesDept = dept === 'All' || a.dept === dept;
                
                return matchesQuery && matchesCat && matchesStatus && matchesDept;
            });

            renderAssets(filtered);
        }

        function openRegisterModal() {
            document.getElementById('registerModal').style.display = 'flex';
        }

        function closeRegisterModal() {
            document.getElementById('registerModal').style.display = 'none';
        }

        function handleRegisterSubmit(e) {
            e.preventDefault();
            const name = document.getElementById('addAssetName').value;
            const category = document.getElementById('addAssetCategory').value;
            const serial = document.getElementById('addAssetSerial').value;
            const location = document.getElementById('addAssetLocation').value;
            const status = document.getElementById('addAssetStatus').value;

            const nextTag = "AF-" + String(assets.length + 13).padStart(4, '0');

            const newAsset = {
                id: nextTag,
                name,
                category,
                status,
                location,
                dept: "Engineering"
            };

            assets.push(newAsset);
            filterAssets();
            closeRegisterModal();
            alert(`Asset registered successfully with tag: ${nextTag}`);
        }

        renderAssets();
    </script>
</body>
</html>
