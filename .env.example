NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/asset_management?schema=public"

# JWT Configuration
JWT_ACCESS_SECRET=change-this-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_SECRET=change-this-reset-secret
JWT_RESET_EXPIRES_IN=1h
JWT_EMAIL_VERIFY_SECRET=change-this-verify-secret
JWT_EMAIL_VERIFY_EXPIRES_IN=24h

BCRYPT_SALT_ROUNDS=12

# SMTP Configuration for Email Service
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@example.com
CLIENT_URL=http://localhost:3000

MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

LOG_LEVEL=debug
LOG_FILE_PATH=./logs
