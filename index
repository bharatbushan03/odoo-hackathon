<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AssetFlow Dashboard</title>

    <link rel="stylesheet" href="style.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container-fluid">
    <div class="row">

        
        <div class="col-md-2 sidebar">
            <h2 class="logo">AssetFlow</h2>

            <ul class="menu">
                <li>Dashboard</li>
                <li>Organization Setup</li>
                <li>Assets</li>
                <li>Allocation & Transfer</li>
                <li>Resource Booking</li>
                <li>Maintenance</li>
                <li>Audit</li>
                <li>Reports</li>
                <li>Notifications</li>
            </ul>
        </div>


        <div class="col-md-10 p-5">

            <h1 class="mb-4">Today's Overview</h1>

            <div class="row g-3">

                <div class="col-md-4">
                    <div class="card-box">
                        <h5>Available</h5>
                        <h2>128</h2>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card-box">
                        <h5>Allocated</h5>
                        <h2>76</h2>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card-box">
                        <h5>Available</h5>
                        <h2>4</h2>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card-box">
                        <h5>Active Bookings</h5>
                        <h2>9</h2>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card-box">
                        <h5>Pending Transfers</h5>
                        <h2>3</h2>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card-box">
                        <h5>Upcoming Returns</h5>
                        <h2>12</h2>
                    </div>
                    </div>

            
            <div class="alert-box">
                3 assets overdue for return – Flagged for follow-up
            </div>

            
            <div class="mt-4">
                <button class="btn btn-success btn-custom">Register Asset</button>
                <button class="btn btn-primary btn-custom">Book Resource</button>
                <button class="btn btn-warning btn-custom">Raise Request</button>
            </div>

           
            <div class="activity">
                <h3>Recent Activity</h3>

                <p> Laptop AF-0114 allocated to Priya Shah</p>

                <p> Room B2 booking confirmed</p>

                <p> Projector AF-0062 maintenance resolved</p>
            </div>

        </div>
                </div>

            </div>

        </div>

    </div>
</div>

<script src="script.js"></script>

</body>
</html>
